generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique
  password  String
  name      String
  email     String   @unique
  role      String   @default("sales") // sales | dev
  phone     String?
  team      String?
  position  String?  // 직급: 팀장, 대리, 이사 등
  createdAt DateTime @default(now())

  createdQuotes  Quote[] @relation("CreatedBy")
  reviewedQuotes Quote[] @relation("ReviewedBy")
  comments       QuoteComment[]
}

model Module {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  category        String   // common | camera | qr | text | server | ai | etc
  description     String?
  basePrice       Int
  isAutoIncluded  Boolean  @default(false)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quoteItems QuoteItem[]
}

model Quote {
  id              String   @id @default(cuid())
  quoteNumber     String   @unique
  status          String   @default("pending") // draft | pending | reviewing | approved | rejected
  type            String   @default("rental") // sale | rental | re_event

  // 기본 정보
  eventName       String
  eventDate       String?
  eventEndDate    String?
  venue           String?
  deadline        String?
  expectedVisitors String?
  requesterName   String
  requesterContact String?
  requesterEmail  String?

  // 장비/환경 정보
  screenDevice      String?  // kiosk | tablet | laptop
  screenResolution  String?
  screenComposition String?  // JSON array: ["splash","camera","printing","complete"]
  printerType       String?  // Smart31 | Smart51 | Joyspace | Luka
  networkType       String?  // wifi | offline | both
  printSize         String?
  ksnetMerchantId   String?  // KSNET 가맹점번호

  // 확정 정보 (사업팀이 클라이언트 확인 후 입력)
  confirmedAt      DateTime?  // 확정일시
  confirmedDate    String?    // 행사 시작일 (확정 후)
  confirmedEndDate String?    // 행사 종료일 (확정 후)
  devDeadline      String?    // 개발 마감일
  devCompletedAt   DateTime?  // 개발 완료(배포) 일시
  lostReason       String?    // 미진행 사유

  // 숨김 (요청자가 삭제 시 화면에서만 숨김, DB 유지)
  isHidden        Boolean  @default(false)

  // 기타
  notes           String?
  rejectionReason String?
  revisionReason  String?  // 사업팀 수정 요청 사유 (approved → reviewing 되돌릴 때)
  reviewNote      String?
  attachments     Json?    // [{fileName, originalName, size, mimeType}]

  // 금액
  subtotal        Int      @default(0)
  vat             Int      @default(0)
  totalAmount     Int      @default(0)

  // 관계
  createdById     String?
  createdBy       User?    @relation("CreatedBy", fields: [createdById], references: [id])
  reviewedById    String?
  reviewedBy      User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  items           QuoteItem[]
  comments        QuoteComment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      Module? @relation(fields: [moduleId], references: [id])

  sortOrder   Int     @default(0)
  itemName    String
  description String?
  unitPrice   Int
  quantity    Int     @default(1)
  amount      Int
  note        String?
  isRequired  Boolean @default(true)  // 필수=true, 선택=false (협상 시 cut 가능 여부)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
}

model QuoteComment {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([createdAt])
}

// 참고 견적 (과거 우리가 보낸 견적, 매출 관리/단가 baseline 참고용)
model ReferenceQuote {
  id            String   @id @default(cuid())
  source        String   // 협력사: "원카드시스템"
  projectName   String   // "MAP내방객솔루션", "신반포22차 아파트 커뮤니티"
  quoteDate     String   // YYYY-MM-DD (필수)
  revision      Int      @default(1)         // 1차/2차/3차
  isFinal       Boolean  @default(false)
  category      String?  // "내방객", "출입통제", "스마트빌딩", "커뮤니티"
  type          String   @default("sale")    // sale | rental | re_event

  // 금액
  subtotal      Int      @default(0)
  vat           Int      @default(0)
  totalAmount   Int      @default(0)

  // 예외 분류 (baseline 평균에서 제외)
  isException     Boolean @default(false)
  exceptionReason String? // "초안/이전 버전", "사이드+자동화 할인", "특수 케이스"

  // 원본 파일 + 부속 자료
  sourceFile    String?  // 원본 xlsx 로컬 경로
  attachments   Json?    // [{type, fileName, localPath, bytes}]

  // 추출 원본 (디버깅/재처리용)
  parsedRaw     Json?

  notes         String?

  items         ReferenceQuoteItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([source])
  @@index([quoteDate])
  @@index([category])
  @@index([projectName])
  @@index([isException])
}

model ReferenceQuoteItem {
  id          String  @id @default(cuid())
  refQuoteId  String
  refQuote    ReferenceQuote @relation(fields: [refQuoteId], references: [id], onDelete: Cascade)
  sortOrder   Int     @default(0)
  itemName    String
  description String?
  unitPrice   Int     @default(0)
  quantity    Int     @default(1)
  amount      Int     @default(0)
  note        String?
  normalizedName String? // 항목명 정규화 (baseline 분석용 그룹핑)

  createdAt   DateTime @default(now())

  @@index([refQuoteId])
  @@index([itemName])
  @@index([normalizedName])
}
